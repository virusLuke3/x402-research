{
  "name": "x402-research",
  "version": "0.1.0",
  "private": true,
  "description": "AutoScholar: x402-powered agentic research network MVP",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --workspace apps/backend run build",
    "build:frontend": "npm --workspace apps/frontend run build",
    "test": "clarinet check && vitest run tests/autoscholar-payments.test.ts"
  },
  "devDependencies": {
    "@hirosystems/clarinet-sdk": "^3.8.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
